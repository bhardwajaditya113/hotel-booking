# ===================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION - Auth Fix Applied
# ===================================================================
# 
# This is the template for production .env on Railway
# Set these variables in Railway -> Project -> Variables section
#
# Key changes for auth fix:
# - SESSION_DRIVER=cookie (instead of file)
# - CACHE_DRIVER=database (instead of file)  
# - SESSION_ENCRYPT=true (enables encrypted cookies)
# - SESSION_SECURE_COOKIE=true (HTTPS only)
#
# ===================================================================

APP_NAME=Elapse
APP_ENV=production
APP_DEBUG=false
APP_URL=https://www.infinityloop.online
APP_KEY=base64:NOfW0RUr+sAq1mbvTH4xn89AuyhNuoupw3ZudsMMlnU=

LOG_CHANNEL=stack
LOG_LEVEL=info

# ===================================================================
# DATABASE CONFIGURATION
# ===================================================================
# Railway provides DATABASE_URL which is automatically parsed by Laravel
DB_CONNECTION=pgsql
DB_HOST=${DATABASE_HOST}
DB_PORT=${DATABASE_PORT}
DB_DATABASE=${DATABASE_NAME}
DB_USERNAME=${DATABASE_USERNAME}
DB_PASSWORD=${DATABASE_PASSWORD}

# ===================================================================
# SESSION CONFIGURATION (CRITICAL AUTH FIX)
# ===================================================================
# Use cookie-based sessions for stateless/containerized environments
SESSION_DRIVER=cookie
SESSION_ENCRYPT=true
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=.infinityloop.online
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ===================================================================
# CACHE CONFIGURATION (CRITICAL AUTH FIX)
# ===================================================================
# Use database cache for rate limiting and auth caching across instances
CACHE_DRIVER=database
CACHE_PREFIX=elapse_

# ===================================================================
# FILESYSTEM CONFIGURATION
# ===================================================================
FILESYSTEM_DISK=local
FILESYSTEM_LOCAL_ROOT=storage/app

# ===================================================================
# BROADCAST & QUEUE CONFIGURATION
# ===================================================================
BROADCAST_DRIVER=reverb
QUEUE_CONNECTION=sync

# ===================================================================
# MAIL CONFIGURATION
# ===================================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=${MAIL_USERNAME}
MAIL_PASSWORD=${MAIL_PASSWORD}
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@infinityloop.online
MAIL_FROM_NAME="${APP_NAME}"

# ===================================================================
# PAYMENT CONFIGURATION (Razorpay)
# ===================================================================
RAZORPAY_KEY=rzp_live_SDwpkGogBOQ7NU
RAZORPAY_SECRET=${RAZORPAY_SECRET}
RAZORPAY_KEY_ID=rzp_live_SDwpkGogBOQ7NU
RAZORPAY_KEY_SECRET=${RAZORPAY_SECRET}
RAZORPAY_WEBHOOK_URL=https://www.infinityloop.online/webhooks/razorpay
RAZORPAY_WEBHOOK_SECRET=${RAZORPAY_WEBHOOK_SECRET}

# ===================================================================
# WEBSOCKET CONFIGURATION (Reverb)
# ===================================================================
REVERB_APP_ID=237912
REVERB_APP_KEY=${REVERB_APP_KEY}
REVERB_APP_SECRET=${REVERB_APP_SECRET}
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="reverb.infinityloop.online"
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# ===================================================================
# STRIPE CONFIGURATION (if needed)
# ===================================================================
STRIPE_PUBLIC_KEY=${STRIPE_PUBLIC_KEY}
STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET}

# ===================================================================
# AUTHENTICATION CONFIGURATION
# ===================================================================
AUTH_PROVIDER=users
AUTH_GUARD=web

# ===================================================================
# SANCTUM CONFIGURATION (API)
# ===================================================================
SANCTUM_STATEFUL_DOMAINS=infinityloop.online,www.infinityloop.online

# ===================================================================
# MONITORING & DEBUGGING (Production)
# ===================================================================
# Keep DEBUG=false in production
# Monitor logs in Railway -> Logs tab
TELESCOPE_ENABLED=false
HORIZON_ENABLED=false

# ===================================================================
# NOTES FOR DEPLOYMENT
# ===================================================================
# 1. After deploying this config, run on production:
#    - php artisan migrate --force
#    - php artisan cache:clear
#    - php artisan config:clear
#
# 2. Verify auth works:
#    - Test login: https://www.infinityloop.online/login
#    - Test register: https://www.infinityloop.online/register
#
# 3. Monitor logs for errors:
#    - Railway console: https://railway.app/project/*/logs
#    - Or via: railway logs --follow
#
# ===================================================================
